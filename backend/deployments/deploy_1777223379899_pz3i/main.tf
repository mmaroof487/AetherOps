resource "aws_vpc" {           # VPC Resource in AWS which will be used to create a new infrastructure.   This is our public/private subnet scenario - Public Subnets & Private ones are divided based on the requirement of this Tier – Standard (2,3) as per requirements
  cidr_block = var.vpc_cidr    // CIDR block for VPC using variable in Terraform configuration file or it can be any existing value which aligns with our need if not then please provide the correct one according to requirement  and usage of this resource is forbidden from here
  tags = {                     # Tags used while creating a new infrastructure. It'll show up as an output once created but in some case we do NOT want such information appearing publicly due security reasons (only with Terraform command line)     // Please change it according to requirements and usage of this resource is forbidden from here
    Name = var.prefix + "-vpc" // Use variable for prefix name when creating resources which ensures clean naming convention  if not then please provide the correct one in accordance by requirement or purpose setting using terraform console (Terrafrom Console) command can be used to see and use this resource's output value as well.
  }
}                                 // The end of vpc block is there for clarity, it should remain without any content here due Terraformer will not print out such lines   */ 
