{
	"testEnvironment": "jsdom",
	"setupFilesAfterEnv": ["<rootDir>/src/setupTests.js"],
	"moduleNameMapper": {
		"\\.(css|less|scss|sass)$": "identity-obj-proxy"
	},
	"transform": {
		"^.+\\.(js|jsx)$": "babel-jest"
	},
	"collectCoverageFrom": ["src/**/*.{js,jsx}", "!src/index.js", "!src/main.jsx", "!src/**/*.test.{js,jsx}"],
	"testMatch": ["<rootDir>/src/**/__tests__/**/*.{js,jsx}", "<rootDir>/src/**/*.{spec,test}.{js,jsx}"],
	"coverageThreshold": {
		"global": {
			"branches": 50,
			"functions": 50,
			"lines": 50,
			"statements": 50
		}
	}
}
