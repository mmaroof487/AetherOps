# Docker Development Configuration

# Enable debug logging
DEBUG=false

# Node environment
NODE_ENV=development

# Backend port (internal)
BACKEND_PORT=3001

# Frontend port (internal)
FRONTEND_PORT=5175

# Ollama configuration
OLLAMA_HOST=http://ollama:11434

# API configuration
REACT_APP_API_URL=http://localhost:3001

# Deployment directory (persisted volume)
DEPLOYMENTS_DIR=/app/backend/deployments

# Temp directory
TEMP_DIR=/app/backend/temp
